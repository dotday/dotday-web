# DOTDAY site configuration
# Copy to .env.local for local dev; set the same vars in Vercel project settings.

# Public site origin (used for canonical URLs, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://www.thedotday.com

# Where the Wix store lives (commerce stays on Wix for now)
NEXT_PUBLIC_STORE_URL=https://store.thedotday.com

