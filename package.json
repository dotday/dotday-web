{
  "name": "dotday-web",
  "version": "1.0.0",
  "private": true,
  "description": "DOTDAY Landscape Fabrics - Next.js site. Shared shell + self-contained JSON content files.",
  "scripts": {
    "dev": "next dev",
    "build": "npm run content:validate && next build",
    "start": "next start",
    "lint": "next lint",
    "content:schema": "node scripts/validate-schema.mjs",
    "content:validate": "node scripts/gen-types.mjs --check && node scripts/gen-catalog.mjs --check && node scripts/validate-schema.mjs && node scripts/validate-post.mjs content/blog && node scripts/validate-content.mjs && node scripts/validate-landing.mjs content/landing && node scripts/brand-guard.mjs",
    "new:blog": "node scripts/new-blog.mjs",
    "content:types": "node scripts/gen-types.mjs",
    "preview:landing": "node scripts/preview-page.mjs landing",
    "preview:blog": "node scripts/preview-page.mjs blog",
    "preview:gallery": "node scripts/preview-gallery.mjs",
    "content:catalog": "node scripts/gen-catalog.mjs"
  },
  "dependencies": {
    "next": "^14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.24.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
