{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/landingPage.schema.json",
  "title": "DOTDAY Landing Page",
  "description": "Data contract for a DOTDAY landing page. A landing page is assembled from an approved set of sections in any order.",
  "type": "object",
  "required": [
    "schemaVersion",
    "slug",
    "title",
    "focusKeyword",
    "status",
    "publishedAt",
    "seo",
    "sections"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "focusKeyword": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "planned",
        "draft",
        "in-review",
        "published",
        "needs-update"
      ]
    },
    "author": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string"
    },
    "dateModified": {
      "type": "string"
    },
    "images": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "seo": {
      "type": "object",
      "required": [
        "metaTitle",
        "metaDescription",
        "canonical",
        "ogImage"
      ],
      "additionalProperties": false,
      "properties": {
        "metaTitle": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        },
        "metaDescription": {
          "type": "string",
          "minLength": 50,
          "maxLength": 160
        },
        "canonical": {
          "type": "string"
        },
        "noindex": {
          "type": "boolean"
        },
        "ogType": {
          "const": "website"
        },
        "twitterCard": {
          "const": "summary_large_image"
        },
        "ogImage": {
          "$ref": "#/$defs/imageRef"
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "imageRef": {
      "type": "object",
      "required": [
        "ref",
        "alt"
      ],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "type": "string"
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "caption": {
          "type": "string",
          "maxLength": 160
        }
      }
    },
    "cta": {
      "type": "object",
      "required": [
        "label",
        "href"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "href": {
          "type": "string"
        }
      }
    },
    "section": {
      "oneOf": [
        {
          "$ref": "#/$defs/hero"
        },
        {
          "$ref": "#/$defs/problem"
        },
        {
          "$ref": "#/$defs/solution"
        },
        {
          "$ref": "#/$defs/useCaseGrid"
        },
        {
          "$ref": "#/$defs/productComparison"
        },
        {
          "$ref": "#/$defs/calculatorEmbed"
        },
        {
          "$ref": "#/$defs/faq"
        },
        {
          "$ref": "#/$defs/reviews"
        },
        {
          "$ref": "#/$defs/cta_section"
        },
        {
          "$ref": "#/$defs/internalLinks"
        },
        {
          "$ref": "#/$defs/steps"
        },
        {
          "$ref": "#/$defs/callout"
        },
        {
          "$ref": "#/$defs/statementBand"
        },
        {
          "$ref": "#/$defs/bigTypeFeatures"
        },
        {
          "$ref": "#/$defs/specSheet"
        },
        {
          "$ref": "#/$defs/projectSpotlight"
        },
        {
          "$ref": "#/$defs/editorialCards"
        },
        {
          "$ref": "#/$defs/videoFeature"
        }
      ]
    },
    "hero": {
      "type": "object",
      "required": [
        "_type",
        "heading"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "hero"
        },
        "eyebrow": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "subheading": {
          "type": "string"
        },
        "image": {
          "$ref": "#/$defs/imageRef"
        },
        "primaryCta": {
          "$ref": "#/$defs/cta"
        },
        "secondaryCta": {
          "$ref": "#/$defs/cta"
        }
      }
    },
    "problem": {
      "type": "object",
      "required": [
        "_type",
        "heading",
        "body"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "problem"
        },
        "eyebrow": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "solution": {
      "type": "object",
      "required": [
        "_type",
        "heading",
        "body",
        "product",
        "productHref"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "solution"
        },
        "eyebrow": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "product": {
          "enum": [
            "SHIELD",
            "XBAR",
            "TERRA"
          ]
        },
        "productHref": {
          "type": "string"
        },
        "image": {
          "$ref": "#/$defs/imageRef"
        },
        "cta": {
          "$ref": "#/$defs/cta"
        }
      }
    },
    "useCaseGrid": {
      "type": "object",
      "required": [
        "_type",
        "cards"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "useCaseGrid"
        },
        "heading": {
          "type": "string"
        },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "title",
              "body"
            ],
            "additionalProperties": false,
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              },
              "href": {
                "type": "string"
              },
              "eyebrow": {
                "type": "string"
              },
              "ctaLabel": {
                "type": "string"
              },
              "image": {
                "$ref": "#/$defs/imageRef"
              }
            }
          }
        },
        "eyebrow": {
          "type": "string"
        },
        "intro": {
          "type": "string"
        }
      }
    },
    "productComparison": {
      "type": "object",
      "required": [
        "_type",
        "columns",
        "rows"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "productComparison"
        },
        "heading": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "featuredColumn": {
          "type": "integer"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "calculatorEmbed": {
      "type": "object",
      "required": [
        "_type"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "calculatorEmbed"
        },
        "heading": {
          "type": "string"
        },
        "intro": {
          "type": "string"
        }
      }
    },
    "faq": {
      "type": "object",
      "required": [
        "_type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "faq"
        },
        "heading": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "q",
              "a"
            ],
            "additionalProperties": false,
            "properties": {
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "reviews": {
      "type": "object",
      "required": [
        "_type",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "reviews"
        },
        "heading": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "quote",
              "author"
            ],
            "additionalProperties": false,
            "properties": {
              "quote": {
                "type": "string"
              },
              "author": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "rating": {
                "type": "number",
                "minimum": 0,
                "maximum": 5
              }
            }
          }
        }
      }
    },
    "cta_section": {
      "type": "object",
      "required": [
        "_type"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "cta"
        },
        "eyebrow": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "primaryCta": {
          "$ref": "#/$defs/cta"
        },
        "secondaryCta": {
          "$ref": "#/$defs/cta"
        },
        "tone": {
          "enum": [
            "default",
            "hardscape"
          ]
        }
      }
    },
    "internalLinks": {
      "type": "object",
      "required": [
        "_type",
        "links"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "internalLinks"
        },
        "heading": {
          "type": "string"
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "label",
              "href"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "href": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "steps": {
      "type": "object",
      "required": [
        "_type",
        "steps"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "steps"
        },
        "heading": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "title",
              "body"
            ],
            "additionalProperties": false,
            "properties": {
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "callout": {
      "type": "object",
      "required": [
        "_type",
        "variant",
        "body"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "callout"
        },
        "variant": {
          "enum": [
            "warning",
            "proTip"
          ]
        },
        "heading": {
          "type": "string"
        },
        "body": {
          "type": "string"
        }
      }
    },
    "statementBand": {
      "type": "object",
      "required": [
        "_type",
        "watermark",
        "statement"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "statementBand"
        },
        "watermark": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "string"
          }
        },
        "statement": {
          "type": "string"
        },
        "highlight": {
          "type": "string"
        },
        "leafMark": {
          "type": "boolean"
        }
      }
    },
    "bigTypeFeatures": {
      "type": "object",
      "required": [
        "_type",
        "heading",
        "cards"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "bigTypeFeatures"
        },
        "heading": {
          "type": "string",
          "minLength": 1
        },
        "cta": {
          "$ref": "#/$defs/cta"
        },
        "cards": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": [
              "title",
              "body"
            ],
            "additionalProperties": false,
            "properties": {
              "icon": {
                "enum": [
                  "shield",
                  "drop",
                  "pin",
                  "layers",
                  "sun",
                  "check"
                ]
              },
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "specSheet": {
      "$ref": "https://thedotday.com/schema/sections/specSheet.json"
    },
    "projectSpotlight": {
      "type": "object",
      "required": [
        "_type",
        "quote"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "projectSpotlight"
        },
        "heading": {
          "type": "string"
        },
        "badge": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "image": {
          "$ref": "#/$defs/imageRef"
        },
        "quote": {
          "type": "string",
          "minLength": 1
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "value"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        },
        "benefits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "author": {
          "type": "object",
          "required": [
            "name"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "role": {
              "type": "string"
            },
            "initials": {
              "type": "string"
            }
          }
        },
        "primaryCta": {
          "$ref": "#/$defs/cta"
        },
        "secondaryCta": {
          "$ref": "#/$defs/cta"
        }
      }
    },
    "editorialCards": {
      "type": "object",
      "required": [
        "_type",
        "cards"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "editorialCards"
        },
        "eyebrow": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        },
        "cards": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "object",
            "required": [
              "title",
              "href",
              "excerpt",
              "image",
              "category",
              "author",
              "authorMonogram"
            ],
            "additionalProperties": false,
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "href": {
                "type": "string"
              },
              "excerpt": {
                "type": "string"
              },
              "image": {
                "$ref": "#/$defs/imageRef"
              },
              "category": {
                "type": "string",
                "minLength": 1
              },
              "level": {
                "type": "string"
              },
              "author": {
                "type": "string"
              },
              "authorMonogram": {
                "type": "string",
                "minLength": 1,
                "maxLength": 3
              },
              "readTime": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "videoFeature": {
      "type": "object",
      "required": [
        "_type"
      ],
      "additionalProperties": false,
      "properties": {
        "_type": {
          "const": "videoFeature"
        },
        "eyebrow": {
          "type": "string"
        },
        "heading": {
          "type": "string"
        }
      }
    }
  }
}
