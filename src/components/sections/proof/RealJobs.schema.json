{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/realJobs.json",
  "title": "RealJobsSection",
  "description": "Schema for the realJobs section (component RealJobs). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of realJobs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "tiles"
  ],
  "properties": {
    "_type": {
      "const": "realJobs"
    },
    "heading": {
      "type": "string"
    },
    "sub": {
      "type": "string"
    },
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "src",
              "alt"
            ],
            "properties": {
              "kind": {
                "const": "image"
              },
              "src": {
                "type": "string"
              },
              "alt": {
                "type": "string"
              },
              "span": {
                "enum": [
                  "wide",
                  "tall"
                ]
              },
              "caption": {
                "type": "string"
              },
              "tag": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "src",
              "poster",
              "alt"
            ],
            "properties": {
              "kind": {
                "const": "video"
              },
              "src": {
                "type": "string"
              },
              "poster": {
                "type": "string"
              },
              "alt": {
                "type": "string"
              },
              "span": {
                "enum": [
                  "wide",
                  "tall"
                ]
              },
              "caption": {
                "type": "string"
              },
              "tag": {
                "type": "string"
              }
            }
          }
        ]
      }
    }
  }
}