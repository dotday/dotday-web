{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/testimonials.json",
  "title": "TestimonialsSection",
  "description": "Schema for the testimonials section (component Testimonials). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of testimonials.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "heading",
    "quotes"
  ],
  "properties": {
    "_type": {
      "const": "testimonials"
    },
    "badge": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "quotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "body",
          "name"
        ],
        "properties": {
          "body": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "product": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          }
        }
      }
    }
  }
}