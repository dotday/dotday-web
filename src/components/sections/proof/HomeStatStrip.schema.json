{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/homeStatStrip.json",
  "title": "HomeStatStripSection",
  "description": "Schema for the homeStatStrip section (component HomeStatStrip). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of homeStatStrip.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "stats"
  ],
  "properties": {
    "_type": {
      "const": "homeStatStrip"
    },
    "stats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "value",
          "label"
        ],
        "properties": {
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "sub": {
            "type": "string"
          },
          "star": {
            "type": "boolean"
          }
        }
      }
    }
  }
}