{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/splitHero.json",
  "title": "HomeHeroSection",
  "description": "Schema for the splitHero section (component HomeHero). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of splitHero.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "headline",
    "card"
  ],
  "properties": {
    "_type": {
      "const": "splitHero"
    },
    "eyebrow": {
      "type": "string"
    },
    "headline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lines"
      ],
      "properties": {
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "highlightLine": {
          "type": "integer"
        }
      }
    },
    "subheading": {
      "type": "string"
    },
    "ctas": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "href"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "variant": {
            "enum": [
              "primary",
              "ghost"
            ]
          }
        }
      }
    },
    "trust": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lead"
        ],
        "properties": {
          "lead": {
            "type": "string"
          },
          "rest": {
            "type": "string"
          }
        }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image",
        "imageAlt"
      ],
      "properties": {
        "tag": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string"
        },
        "videoMp4": {
          "type": "string"
        },
        "videoWebm": {
          "type": "string"
        },
        "stats": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "value",
              "label"
            ],
            "properties": {
              "value": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "star": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}