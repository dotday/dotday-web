{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/installShowcase.json",
  "title": "InstallShowcaseSection",
  "description": "Schema for the installShowcase section (component InstallShowcase). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of installShowcase.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "heading",
    "feature",
    "side",
    "stats"
  ],
  "properties": {
    "_type": {
      "const": "installShowcase"
    },
    "badge": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "intro": {
      "type": "string"
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eyebrow",
        "title",
        "body",
        "href",
        "image",
        "alt"
      ],
      "properties": {
        "eyebrow": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "href": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      }
    },
    "side": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "eyebrow",
          "title",
          "body",
          "href",
          "image",
          "alt"
        ],
        "properties": {
          "eyebrow": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        }
      }
    },
    "stats": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "sub"
        ],
        "properties": {
          "value": {
            "type": "string"
          },
          "icon": {
            "type": "boolean"
          },
          "label": {
            "type": "string"
          },
          "sub": {
            "type": "string"
          }
        }
      }
    }
  }
}