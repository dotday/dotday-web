{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/groundConditionCards.json",
  "title": "UseCasesSection",
  "description": "Schema for the groundConditionCards section (component UseCases). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of groundConditionCards.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "heading",
    "cards"
  ],
  "properties": {
    "_type": {
      "const": "groundConditionCards"
    },
    "badge": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "intro": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "body",
          "pick",
          "href",
          "image",
          "alt"
        ],
        "properties": {
          "eyebrow": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "pick": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          },
          "ctaLabel": {
            "type": "string"
          }
        }
      }
    }
  }
}