{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/specSheet.json",
  "title": "SpecSheetSection",
  "description": "Spec sheet section: a heading + intro and a list of value/label spec rows, optional image and footnote. This file is the SINGLE SOURCE OF TRUTH for the section's shape - the TS type is generated from it (SpecSheet.types.ts) and the landing-page doc schema $refs it.",
  "type": "object",
  "required": [
    "_type",
    "heading",
    "rows"
  ],
  "additionalProperties": false,
  "properties": {
    "_type": {
      "const": "specSheet"
    },
    "tag": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "intro": {
      "type": "string"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "value",
          "label"
        ],
        "additionalProperties": false,
        "properties": {
          "value": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "standard": {
            "type": "string"
          },
          "emphasis": {
            "enum": [
              "neon",
              "plain"
            ]
          }
        }
      }
    },
    "image": {
      "$ref": "#/$defs/imageRef"
    },
    "footnote": {
      "type": "string"
    }
  },
  "$defs": {
    "imageRef": {
      "title": "ImageRef",
      "type": "object",
      "required": [
        "ref",
        "alt"
      ],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "type": "string"
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "caption": {
          "type": "string",
          "maxLength": 160
        }
      }
    }
  }
}
