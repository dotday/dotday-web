{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/applicationGallery.json",
  "title": "ApplicationGallerySection",
  "description": "Schema for the applicationGallery section (component ApplicationGallery). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of applicationGallery.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "heading",
    "apps"
  ],
  "properties": {
    "_type": {
      "const": "applicationGallery"
    },
    "eyebrow": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "sub": {
      "type": "string"
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "icon",
          "title",
          "product",
          "body",
          "image",
          "alt",
          "href"
        ],
        "properties": {
          "icon": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "product": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          },
          "href": {
            "type": "string"
          }
        }
      }
    }
  }
}