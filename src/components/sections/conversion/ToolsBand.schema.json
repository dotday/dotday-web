{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/toolsBand.json",
  "title": "ToolsBandSection",
  "description": "Schema for the toolsBand section (component ToolsBand). Derived from its home/types.ts data shape so this section can be used and validated on landing pages. SINGLE SOURCE OF TRUTH for landing usage of toolsBand.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "_type",
    "tools"
  ],
  "properties": {
    "_type": {
      "const": "toolsBand"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "icon",
          "title",
          "body",
          "cta",
          "href"
        ],
        "properties": {
          "icon": {
            "type": "string"
          },
          "kicker": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "cta": {
            "type": "string"
          },
          "href": {
            "type": "string"
          }
        }
      }
    }
  }
}