{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://thedotday.com/schema/sections/dualBenefit.json",
  "title": "DualBenefitSection",
  "description": "Dual-benefit feature block: a centered eyebrow + heading + intro, then two image cards, each with a short tag, a titled benefit, and a paragraph. Built to show one product doing two jobs (e.g. weed control and drainage). This file is the SINGLE SOURCE OF TRUTH for the section's shape - the TS type is generated from it (DualBenefit.types.ts) and the landing-page doc schema $refs it.",
  "type": "object",
  "required": [
    "_type",
    "heading",
    "cards"
  ],
  "additionalProperties": false,
  "properties": {
    "_type": {
      "const": "dualBenefit"
    },
    "eyebrow": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "highlight": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "cards": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": [
          "title",
          "body"
        ],
        "additionalProperties": false,
        "properties": {
          "tag": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "image": {
            "$ref": "#/$defs/imageRef"
          }
        }
      }
    },
    "cta": {
      "$ref": "#/$defs/cta"
    }
  },
  "$defs": {
    "imageRef": {
      "title": "ImageRef",
      "type": "object",
      "required": [
        "ref",
        "alt"
      ],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "type": "string"
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "caption": {
          "type": "string",
          "maxLength": 160
        }
      }
    },
    "cta": {
      "title": "Cta",
      "type": "object",
      "required": [
        "label",
        "href"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "href": {
          "type": "string"
        }
      }
    }
  }
}
